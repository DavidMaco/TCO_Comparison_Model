# TCO Comparison Model — Environment Variables
# Copy to .env and fill in values

# Database
MYSQL_ROOT_PASSWORD=tco_root_pw
MYSQL_DATABASE=tco_comparison
MYSQL_USER=tco_user
MYSQL_PASSWORD=tco_password
TCO_DB_HOST=localhost
TCO_DB_PORT=3306

# Dev mode (bypasses DB requirement)
TCO_DEV_MODE=true

# FX API (optional — falls back to anchor rates)
FX_API_KEY=
FX_API_URL=https://api.exchangerate-api.com/v4/latest/USD

# API CORS — comma-separated allowed origins
TCO_CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# API authentication (optional — leave blank to disable)
TCO_API_KEY=

# Rate limiting (requests per window)
TCO_RATE_LIMIT=60
TCO_RATE_WINDOW=60

# Monte Carlo defaults
MC_DEFAULT_SIMULATIONS=10000
MC_DEFAULT_SEED=42
